---
// src/components/Header.astro
// Minimaler Header.
// Auf Mobile bleibt er bewusst unauffällig, damit die HeroSection wie im Entwurf wirken kann.
// Später ergänzen wir hier Navigation, Sprachwechsel und ggf. Menü.
---

<header class="site-header">
  <a class="site-logo" href="/" aria-label="Zur Startseite">
  <img src="/favicon.svg" alt="" class="site-logo-icon" />
  <span>Kollektiv</span>
</a>

  <nav class="site-nav" ria-label="Hauptnavigation">
  <a class="site-nav__hand" href="#framework">Zum Test</a>
  <a class= href="#case">Case Studies</a>
  <a href="#about">Über das Projekt</a>
</nav>
</header>
<style>
  .site-header {
    position: absolute;
    z-index: 20;
    top: 0;
    left: 0;
    width: 100%;

    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;

    padding: 1.25rem var(--page-padding-x);

    color: var(--color-text);
    font-family: var(--font-body);
  }

  .site-logo {
	font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 900;
    letter-spacing: -0.04em;
  }

  .site-nav {
    display: none;
    align-items: center;
    gap: 1.75rem;
 	font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 900;
    letter-spacing: -0.03em;
  }
  .site-nav__hand {
    font-family: var(--font-hand);
    font-size: 1.25rem;
    font-weight: 400;
    letter-spacing: 0;
	color: var(--color-accent);
  }

  @media (min-width: 768px) {
    .site-nav {
      display: flex;
    }
  }
</style>