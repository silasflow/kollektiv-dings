---
interface Props {
	lang: "de" | "en";
	nav: {
		test: string;
		caseStudies: string;
		about: string;
		languageLabel: string;
		languageHref: string;
	};
}

const { lang, nav } = Astro.props;

const otherLang = lang === "de" ? "en" : "de";
const currentPath = Astro.url.pathname;

const normalizePath = (path: string) => path.replace(/\/$/, "");

const isActive = (href: string) => {
	const normalizedPath = normalizePath(currentPath);
	const normalizedHref = normalizePath(href);

	return (
		normalizedPath === normalizedHref ||
		normalizedPath.startsWith(`${normalizedHref}/`)
	);
};

const testHref = `/${lang}/test/`;
const caseStudiesHref = `/${lang}/case-studies/`;
const aboutHref = `/${lang}/about/`;
const languageHref = currentPath.replace(`/${lang}`, `/${otherLang}`);
---

<header class="site-header">
	<script>
		document.addEventListener("DOMContentLoaded", () => {
			let menuOpen = false;
			const header = document.querySelector(".site-header");
			const toggle = document.getElementById("menuToggle");
			const menu = document.getElementById("menu");
			const body = document.body;

			function setScrollLock(locked: boolean) {
				body.style.overflow = locked ? "hidden" : "";
				body.style.touchAction = locked ? "none" : "";
			}

			if (toggle && menu && header) {
				toggle.addEventListener("click", () => {
					menuOpen = !menuOpen;
					menu.classList.toggle("open", menuOpen);
					header.classList.toggle("open", menuOpen);
					setScrollLock(menuOpen);
					toggle.textContent = menuOpen ? "Schließen" : "Menü";
				});
			}

			window.addEventListener("beforeunload", () => setScrollLock(false));
		});
	</script>

	<a class="site-logo" href={`/${lang}/`} aria-label="Startseite">
		<img src="/favicon.svg" alt="" class="site-logo-icon" />
	</a>

	<nav class="site-nav-desktop" aria-label="Hauptnavigation">
		<a class:list={{ active: isActive(testHref) }} href={testHref}>
			{nav.test}
		</a>

		<a
			class:list={{ active: isActive(caseStudiesHref) }}
			href={caseStudiesHref}
		>
			{nav.caseStudies}
		</a>

		<a class:list={{ active: isActive(aboutHref) }} href={aboutHref}>
			{nav.about}
		</a>

		<a class="language-switch" href={languageHref}>
			{nav.languageLabel}
		</a>
	</nav>

	<nav class="site-nav-mobile" aria-label="Hauptnavigation">
		<div class="menu-toggle" id="menuToggle">Menü</div>

		<div class="mobile-nav-links" id="menu">
			<a class:list={{ active: isActive(testHref) }} href={testHref}>
				{nav.test}
			</a>

			<a
				class:list={{ active: isActive(caseStudiesHref) }}
				href={caseStudiesHref}
			>
				{nav.caseStudies}
			</a>

			<a class:list={{ active: isActive(aboutHref) }} href={aboutHref}>
				{nav.about}
			</a>

			<a class="language-switch" href={languageHref}>
				{nav.languageLabel}
			</a>
		</div>
	</nav>

	<style>
		.site-header {
			position: absolute;
			z-index: 20;
			top: 0;
			left: 0;
			width: 100%;

			display: flex;
			align-items: center;
			justify-content: space-between;
			gap: 1rem;

			padding: 0.8rem var(--page-padding-x);

			color: var(--color-text);
			font-family: var(--font-body);
		}

		.site-header.open {
			background-color: var(--brand-deep-forest);
		}

		.site-logo {
			display: inline-flex;
			align-items: center;
			text-decoration: none;
		}

		.site-logo-icon {
			display: block;
		}

		.site-nav-desktop {
			display: none;
			align-items: center;
			gap: 0.5rem;

			font-family: var(--font-body);
			font-size: var(--size-p);
			letter-spacing: -0.03em;
		}

		.site-nav-desktop a,
		.mobile-nav-links a {
			text-decoration: none;
			padding: 1rem 0.75rem;

			background-color: transparent;
			color: var(--color-text);
			border-radius: 0.5rem;

			transition:
				color 0.2s ease-in-out,
				background-color 0.2s ease-in-out;
		}

		.site-nav-desktop a:hover {
			background-color: var(--color-card-bg);
		}

		.mobile-nav-links a:hover {
			background-color: var(--color-bg);
		}

		.site-nav-desktop a.active,
		.mobile-nav-links a.active {
			color: var(--color-accent);
			font-family: var(--font-hand);
			font-size: var(--size-p-highlight);
			text-decoration: underline;
			text-decoration-thickness: 0.14em;
			text-underline-offset: 0.18em;
			text-decoration-color: var(--color-accent);
		}

		.site-nav-mobile {
			position: relative;
		}

		.menu-toggle {
			cursor: pointer;
			font-family: var(--font-hand);
			font-size: 1.25rem;
			font-weight: 400;
			letter-spacing: 0;
			color: var(--color-text);
		}

		.mobile-nav-links {
			display: none;
			position: fixed;
			top: 72px;
			left: 0;

			width: 100svw;
			flex-direction: column;
			gap: 0.25rem;

			padding: 1rem 2rem;
			background-color: var(--brand-deep-forest);
		}

		.mobile-nav-links.open {
			display: flex;
		}

		.site-nav__hand {
			font-family: var(--font-hand);
			font-size: 1.25rem;
			font-weight: 400;
			letter-spacing: 0;
			color: var(--color-accent);
		}

		@media (min-width: 768px) {
			.site-nav-desktop {
				display: flex;
			}

			.site-nav-mobile {
				display: none;
			}
		}
	</style>
</header>
