---
// Removed Button import to avoid missing module error; using a local link styled as button
import Button from '../common/Button.astro';

interface Props {
  lang: 'de' | 'en';
  content: {
    titleLine1: string;
    titleLine2: string;
    highlight: string;
    titleLine3: string;
    description: string;
    testDescription: string;
    buttonLabel: string;
  };
}

const { lang, content } = Astro.props;
---

<section class="hero" id="start">
 <div class="hero-map" aria-hidden="true"></div>

  <div class="hero-content">
    <h1 class="hero-title">
      <span class="heading1">{content.titleLine1}</span>
      <span class="heading1">{content.titleLine2}</span>
      <span class="script-heading1" style="">{content.highlight}</span>
      <span class="heading1">{content.titleLine3}</span>
    </h1>

    <p class="hero-text paragraph-emphasised">{content.description}</p>

  </div>
  <div class="hero-content-test">
    <h2 class="heading3">
      Du bist selbst Teil eines Kollektivs?
    </h2>
    <h3>
      <span class="heading2">Mache jetzt den</span>
      <span class="script-heading2">Kollektiv-Personality-Test</span>
    </h3>
    <p class="hero-text paragraph">{content.testDescription}</p>
    <Button href={`/${lang}/test/`} label={content.buttonLabel} />
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 4rem;
    min-height: 100svh;
    overflow: hidden;
    background: var(--color-bg);
    isolation: isolate;

    padding-top: var(--page-padding-top);
    padding-right: var(--page-padding-x);
    padding-bottom: 4rem;
    padding-left: var(--page-padding-x);
  }

  .hero-map {
  position: absolute;
  z-index: 0;

  top: -2svh;
  left: -3vw;

  width: 104vw;
  height: 88svh;

  background-image: url("/images/city-map.svg");
  background-repeat: no-repeat;
  background-position: center top;
  background-size: 100% auto;

  opacity: 0.90;
  mix-blend-mode: multiply;
  

  pointer-events: none;

  -webkit-mask-image: linear-gradient(
    to bottom,
    black 0%,
    black 85%,
    transparent 99%
  );
  mask-image: linear-gradient(
    to bottom,
    black 0%,
    black 85%,
    transparent 99%
  );
}
  .hero-content {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    z-index: 1;

    width: 100%;
    max-width: 44rem;
  }
  
  .hero-content-test {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    z-index: 1;
    padding: 0 10%;
  }

  .hero-title {
    margin: 0;
    text-transform: uppercase;

    color: var(--color-text);
  }

  .hero-title span {
    display: block;
    white-space: nowrap;
  }

  .hero-text {
    max-width: 34rem;
    margin: 0;

    color: rgba(232, 255, 242, 0.94);
  }

  .hero-btn {
    display: inline-block;
    margin-top: 1.25rem;
    padding: 0.75rem 1.25rem;
    background: var(--color-accent);
    color: var(--color-bg);
    font-weight: 700;
    text-decoration: none;
    border-radius: 0.5rem;
  }

    @media (max-width: 767px) {
    .hero-map {
    top: -4svh;
    left: -14vw;

    width: 128vw;
    height: 78svh;

    background-size: 100% auto;
    background-position: center top;

    -webkit-mask-image: linear-gradient(
      to bottom,
      black 0%,
      black 52%,
      rgba(0, 0, 0, 0.55) 68%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to bottom,
      black 0%,
      black 52%,
      rgba(0, 0, 0, 0.55) 68%,
      transparent 100%
    );
  }
}
  @media (min-width: 768px) {
  .hero-map {
    top: -2svh;
    left: -2vw;

    width: 104vw;
    height: 86svh;

    background-size: 100% auto;
    background-position: center top;
  }


    .hero-content {
      max-width: 52rem;
    }
  }
 
    
  @media (min-width: 1200px) {
      .hero-map {
    top: -2.5svh;
    left: -1.5vw;

    width: 103vw;
    height: 88svh;

    background-size: 100% auto;
    background-position: center top;
  }

    .hero-title {
      max-width: 58rem;
    }
  }

  @media (min-width: 1600px) {
    .hero-map {
    top: -3svh;
    left: -1vw;

    width: 102vw;
    height: 88svh;

    background-size: 100% auto;
  }
  }
</style>