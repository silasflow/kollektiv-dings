---
import BaseHead from "../../components/common/BaseHead.astro";
import Header from "../../components/common/Header.astro";
import { languages, siteContent, type Lang } from "../../data/siteContent";

export function getStaticPaths() {
	return languages.map((lang) => ({
		params: { lang },
	}));
}

const lang = Astro.params.lang as Lang;
const normalizedLang = lang === "en" ? "en" : "de";

const site = siteContent[normalizedLang];
const otherLang = normalizedLang === "en" ? "de" : "en";

const pages = import.meta.glob("../../content/pages/about.*.md");

const pagePath = `../../content/pages/about.${normalizedLang}.md`;
const fallbackPath = "../../content/pages/about.de.md";

const pageLoader = pages[pagePath] ?? pages[fallbackPath];

if (!pageLoader) {
	throw new Error(
		`About-Markdown nicht gefunden. Erwartet: ${pagePath} oder ${fallbackPath}`,
	);
}

const page = await pageLoader();
const { Content, frontmatter } = page as {
	Content: any;
	frontmatter: {
		title?: string;
		kicker?: string;
		toc?: {
			label: string;
			id: string;
		}[];
	};
};

const pageTitle = frontmatter.title ?? site.meta.title;
const pageDescription = site.meta.description;
const kicker = frontmatter.kicker ?? frontmatter.title;
---

<html lang={normalizedLang}>
	<head>
		<BaseHead title={pageTitle} description={pageDescription} />
	</head>

	<body>
		<Header
			lang={normalizedLang}
			nav={{
				...site.nav,
				languageHref: `/${otherLang}/about/`,
			}}
		/>

		<main class="about-page">
			<div class="hero-map" aria-hidden="true"></div>
			<section class="about-layout">
				<article class="about-content"><Content /></article>

				{
					frontmatter.toc && (
						<aside
							class="about-toc"
							aria-label={
								normalizedLang === "de"
									? "Inhaltsverzeichnis"
									: "Table of contents"
							}
						>
							<nav>
								{frontmatter.toc.map((item) => (
									<a href={`#${item.id}`}>{item.label}</a>
								))}
							</nav>
						</aside>
					)
				}
			</section>
		</main>
	</body>
</html>

<style>
	.hero-map {
		position: absolute;
		z-index: 0;

		top: -2svh;
		left: -3vw;

		width: 104vw;
		height: 88svh;

		background-image: url("/images/newCityMap.svg");
		background-repeat: no-repeat;
		background-position: center top;
		background-size: 100% auto;

		opacity: 0.3;
		mix-blend-mode: multiply;

		pointer-events: none;

		-webkit-mask-image: linear-gradient(
			to bottom,
			black 0%,
			black 85%,
			transparent 99%
		);
		mask-image: linear-gradient(
			to bottom,
			black 0%,
			black 85%,
			transparent 99%
		);
	}
	.about-page {
		min-height: 100svh;

		padding: clamp(4.5rem, 11vh, 7rem) var(--page-padding-x)
			clamp(4rem, 10vh, 6rem);

		background: var(--color-bg);
		color: var(--color-text);
	}

	.about-layout {
		width: min(100%, 48rem);
		margin-inline: auto;

		display: grid;
		grid-template-columns: minmax(0, 1fr) clamp(7rem, 16vw, 10rem);
		gap: clamp(2rem, 6vw, 4rem);
		align-items: start;
	}

	.about-content {
		max-width: 34rem;
	}

	.about-kicker {
		margin: 0 0 1.35rem;

		font-family: var(--font-hand);
		font-size: var(--size-h2-script);
		font-weight: 400;
		line-height: 60%;
		letter-spacing: -3%;
		text-transform: uppercase;
		color: var(--color-text-highlight);
		transform: translateY(10%);
	}

	.about-content :global(h1) {
		margin: 0;

		font-family: var(--font-display);
		font-weight: 700;
		letter-spacing: -0.055em;
		color: var(--color-text);
		letter-spacing: -3%;
	}

	.about-content :global(h2),
	.about-content :global(h3) {
		margin: 0;

		font-family: var(--font-display);
		font-weight: 700;
		letter-spacing: -0.055em;
		color: var(--color-text);
		letter-spacing: -3%;
	}

	.about-content :global(h1) {
		margin-bottom: 1.6rem;
		text-transform: uppercase;
		font-family: var(--font-hand);
		font-size: var(--size-h3-script);
		font-weight: 400;
		line-height: 60%;
		letter-spacing: 0;

		color: var(--color-accent);
	}

	.about-content :global(h1) {
		margin-bottom: 1.6rem;

		line-height: 100%;
	}

	.about-content :global(h2) {
		margin-top: 2.5rem;
		margin-bottom: 0.9rem;

		font-size: var(--size-h3);
		line-height: 110%;
	}

	.about-content :global(h3) {
		margin-top: 1.5rem;
		margin-bottom: 0.65rem;

		font-size: var(--size-h4);
		line-height: 110%;
	}

	.about-content :global(p) {
		margin: 0 0 1rem;

		font-family: var(--font-body);
		font-weight: 400;
		line-height: 130%;
		letter-spacing: 1%;
		font-size: var(--size-p);
	}

	.about-content :global(a) {
		color: var(--color-accent);
		text-decoration-thickness: 0.08em;
		text-underline-offset: 0.18em;
	}

	.about-content :global(ul),
	.about-content :global(ol) {
		margin: 0 0 1.2rem;
		padding-left: 1.2rem;

		color: var(--color-text);
	}

	.about-content :global(li) {
		margin-bottom: 0.35rem;
		line-height: 1.3;
	}

	.about-toc {
		position: sticky;
		top: 5rem;

		padding: 1rem 0.5rem;
		border-radius: 0.25rem;

		background: var(--color-card-bg);
	}

	.about-toc nav {
		display: grid;
		gap: 0.25rem;
	}

	.about-toc a {
		font-family: var(--font-narrow);
		padding: 0.5rem 0.75rem;
		color: var(--color-text);

		font-size: var(--size-label);
		line-height: 1.3;
		text-decoration: none;
	}

	.about-toc a:hover {
		color: var(--color-accent);
	}

	/* .about-toc a:first-child {
		color: var(--color-accent);

		font-family: var(--font-hand);
		font-size: var(--size-p-highlight);
	} */

	@media (max-width: 760px) {
		.about-page {
			padding-top: 5rem;
		}

		.about-layout {
			grid-template-columns: 1fr;
		}

		.about-toc {
			display: none;
		}
	}

	:global(.site-header) {
		position: fixed !important;
		top: 0;
		left: 0;
		right: 0;
		z-index: 100;
	}
</style>
