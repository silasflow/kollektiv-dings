---
// src/pages/index.astro
// Das ist die Startseite der Website.
// Alles in src/pages wird in Astro automatisch zu einer Route.
// Diese Datei entspricht also der URL: /

import BaseHead from "../../components/common/BaseHead.astro";
import Header from "../../components/common/Header.astro";
import Footer from "../../components/common/Footer.astro";
import Hero from "../../components/sections/Hero.astro";
import { languages, siteContent, type Lang } from "../../data/siteContent.ts";

export function getStaticPaths() {
	return languages.map((lang) => ({
		params: { lang },
	}));
}

const lang = Astro.params.lang as Lang;
const normalizedLang = lang === "en" ? "en" : "de";
const t = siteContent[normalizedLang];
const otherLang = normalizedLang === "en" ? "de" : "en";
---

<html lang={normalizedLang}>
	<head>
		<BaseHead title={t.meta.title} description={t.meta.description} />
	</head>

	<body>
		<Header
			lang={normalizedLang}
			nav={{ ...t.nav, languageHref: `/${otherLang}/` }}
		/>

		<main>
			<Hero lang={normalizedLang} content={t.hero} />
		</main>
	</body>
</html>
