---
// src/pages/index.astro
// Das ist die Startseite der Website.
// Alles in src/pages wird in Astro automatisch zu einer Route.
// Diese Datei entspricht also der URL: /

import BaseHead from '../../components/common/BaseHead.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';
import Hero from '../../components/sections/Hero.astro';
import { languages, siteContent, type Lang } from '../../data/siteContent.ts';

export function getStaticPaths() {
  return languages.map((lang) => ({
    params: { lang },
  }));
}

const lang = Astro.params.lang as Lang;
const t = siteContent[lang];
const otherLang = lang === 'en' ? 'de' : 'en';
---
<html lang={lang}>
  <head>
    <BaseHead title={t.meta.title} description={t.meta.description} />
  </head>

  <body>
    <Header lang={lang} nav={{ ...t.nav, languageHref: `/${otherLang}/` }} />

    <main>
      <Hero lang={lang} content={t.hero as any} />
    </main>
  </body>
</html>